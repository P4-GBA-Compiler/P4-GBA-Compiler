def Turn(symbol):
    selecting = True
    while selecting:
        if InputLeft(): #The 'Input' functions return 'True' if the corresponding button is pressed. Otherwise they return 'False'.
            MoveLeft() #The 'Move' functions move the selected tile. This only works if a grid has been created.
                       #The starting position will be [0,0] in the grid. 
        elif InputRight():
            MoveRight()

        elif InputUp():
            MoveUp()

        elif InputDown():
            MoveDown()

        elif InputA():
            Draw(symbol) #Draws the character 'x' or 'o' on the currently selected tile.
            selecting = False

    if symbol == 'x':
        Turn('o')
    else:
        Turn('x')


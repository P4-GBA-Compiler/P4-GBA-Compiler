def Turn(symbol):
    selecting = True
    while selecting:
        if InputLeft():  # The 'Input' functions return 'True' if the corresponding button is pressed. Otherwise they return 'False'.
            # The 'Move' functions move the selected tile. This only works if a grid has been created.
            MoveLeft()
            # The starting position will be [0,0] in the grid.
        elif InputRight():
            MoveRight()

        elif InputUp():
            MoveUp()

        elif InputDown():
            MoveDown()

        elif InputA():
            # Draws the character 'x' or 'o' on the currently selected tile.
            Draw(symbol)
            selecting = False

    if symbol == "x":
        Turn("o")
    else:
        Turn("x")


